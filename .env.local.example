# ─────────────────────────────────────────────────────────────
# whatwedonowmama — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe ────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Your Stripe Plus product/price ID
# Create in: Stripe Dashboard → Products → Add Product
# Price: $7/month, 7-day trial
STRIPE_PLUS_PRICE_ID=price_YOUR_PRICE_ID

# ── App URL ───────────────────────────────────────────────────
# Local: http://localhost:3000
# Production: https://whatwedonowmama.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Beehiiv ───────────────────────────────────────────────────
# Found in: Beehiiv → Settings → Integrations → API
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=pub_YOUR_PUBLICATION_ID

# ── Resend (transactional email) ──────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_YOUR_RESEND_KEY
RESEND_FROM_EMAIL=hello@whatwedonowmama.com
